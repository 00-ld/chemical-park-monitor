# 化工园区智能监测系统 - 环境变量模板
# 复制此文件为 .env 并填入实际值

# 数据库配置
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=chemical

# Java 后端
SPRING_PROFILES_ACTIVE=docker

# JWT 签名密钥（至少 32 字符，务必修改为随机强密钥）
# 生成示例：openssl rand -hex 32
JWT_SECRET=please_change_me_to_a_random_32char_min_secret

# 算法服务共享密钥（Java/nginx 调用 Python 算法服务时校验，务必修改）
# 生成示例：openssl rand -hex 24
ALGORITHM_API_KEY=please_change_me_to_a_random_key

# 算法服务允许的 CORS 来源（逗号分隔），生产填实际域名
ALGORITHM_CORS_ORIGINS=http://localhost

