# Chemical park monitoring system environment template.
# Copy this file to `.env` on the server and replace every placeholder.
# Never commit the real `.env` file to GitHub.

# MySQL
MYSQL_ROOT_PASSWORD=replace_with_strong_mysql_root_password
MYSQL_DATABASE=chemical

# Java backend
SPRING_PROFILES_ACTIVE=docker

# Default area name stored for image-analysis inspection records.
INSPECTION_DEFAULT_LOCATION=核心作业区 A7

# JWT signing secret. Use at least 32 random characters.
# Example: openssl rand -hex 32
JWT_SECRET=replace_with_random_32_char_min_secret

# Shared key used by Nginx / Java backend when calling Python algorithms.
# Example: openssl rand -hex 24
ALGORITHM_API_KEY=replace_with_random_algorithm_key

# YOLO/person analysis service used by Java backend.
# Leave empty if this service is not deployed yet; related image-analysis APIs
# will fail fast instead of silently using a localhost fallback.
ANALYSIS_SERVICE_URL=

# Java backend CORS allowlist.
CORS_ALLOWED_ORIGINS=http://www.cip.lab6119.xyz,https://www.cip.lab6119.xyz

# Python algorithm CORS allowlist.
ALGORITHM_CORS_ORIGINS=http://www.cip.lab6119.xyz,https://www.cip.lab6119.xyz
