{
  "_comment": "GasModelTest 全局配置。单位制: 坐标 m, 风速 m/s, 源强 g/s, 浓度 mg/m3 (=ug/m3 换算见 README). 修改后重新运行 generate_dataset.py 即可复现。",
  "random_seed": 20260608,

  "domain": {
    "x_min": 0.0, "x_max": 2000.0, "nx": 201,
    "y_min": -500.0, "y_max": 500.0, "ny": 101,
    "z_min": 0.0, "z_max": 200.0, "nz": 41,
    "_comment": "x 顺风向(下风距离), y 横风向, z 垂直高度"
  },

  "case01_gaussian_plume": {
    "source": {"x": 0.0, "y": 0.0, "H": 50.0, "Q": 100.0,
               "_comment": "H=有效排放高度 m, Q=源强 g/s"},
    "wind_speed": 5.0,
    "stability_classes": ["A", "B", "C", "D", "E", "F"],
    "stability_3d_export": "D"
  },

  "case02_puff_timeseries": {
    "source": {"x0": 0.0, "y0": 0.0, "H": 30.0,
               "mass": 5000.0, "_comment": "mass=瞬时释放总质量 g"},
    "wind_speed": 4.0,
    "stability": "D",
    "t_start": 0.0, "t_end": 600.0, "nt": 61,
    "receptors": [
      {"name": "R1", "x": 200.0, "y": 0.0, "z": 1.5},
      {"name": "R2", "x": 500.0, "y": 0.0, "z": 1.5},
      {"name": "R3", "x": 800.0, "y": 50.0, "z": 1.5},
      {"name": "R4", "x": 1200.0, "y": -50.0, "z": 1.5}
    ]
  },

  "case03_sensor_observations": {
    "true_source": {"x": 0.0, "y": 0.0, "H": 50.0, "Q": 100.0},
    "wind_speed": 5.0,
    "stability": "D",
    "n_sensors": 15,
    "sensor_height": 1.5,
    "noise": {"snr_db": 20.0, "min_floor": 0.001,
              "_comment": "高斯噪声, 信噪比 20dB; 读数下限 floor 模拟检出限"}
  },

  "case04_multi_source": {
    "true_sources": [
      {"name": "S1", "x": 100.0, "y": 100.0, "H": 40.0, "Q": 80.0},
      {"name": "S2", "x": 100.0, "y": -150.0, "H": 60.0, "Q": 120.0},
      {"name": "S3", "x": 600.0, "y": 50.0, "H": 30.0, "Q": 60.0}
    ],
    "stability": "C",
    "n_sensors": 25,
    "sensor_height": 1.5,
    "wind_field": {
      "base_speed": 4.0, "base_dir_deg": 270.0,
      "t_start": 0.0, "t_end": 1800.0, "nt": 31,
      "speed_amp": 1.0, "dir_amp_deg": 25.0,
      "_comment": "风向以气象约定: 270=正西来风(吹向东). 风速/风向随时间正弦扰动"
    },
    "noise": {"snr_db": 18.0, "min_floor": 0.001}
  }
}
